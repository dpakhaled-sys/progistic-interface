# Copie ce fichier en .env et remplis tes vraies valeurs.

# --- Connexion au Web Service Acrom ---
# Adresse de test fournie dans la doc : webservice.acrom.pro:7000
WS_HOST=webservice.acrom.pro
WS_PORT=7000

# Chemin éventuel sur le serveur (souvent vide / "/"). À ajuster si besoin.
WS_PATH=/

# http ou https selon ce qu'expose le service sur le port 7000
WS_PROTOCOL=http

# Catalogue interrogé dans l'<Entete> DISPO (ex. AUTODATA)
CATALOGUE=AUTODATA

# --- Identifiants (voir <Entete> de la doc) ---
# Pour ACCES : idgarage == idclient (balises identiques d'après la doc)
ID_GARAGE=1234
ID_CLIENT=1234
WS_LOGIN=test

# --- Serveur local ---
PORT=3000

# Mode démo : true = utilise les exemples XML de la doc (sans toucher au vrai service)
# Pratique pour voir l'interface fonctionner avant d'avoir l'accès réseau au :7000
MOCK=true

# --- Connexion à l'interface (page de login) ---
# Identifiant + mot de passe demandés pour accéder à l'interface.
APP_USER=progistique
APP_PASS=change-moi
# Secret de signature des jetons (HMAC). Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT sur Vercel : définir cette variable, sinon les jetons sont invalidés à chaque cold start.
AUTH_SECRET=mets-un-secret-aleatoire-long-ici
